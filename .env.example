# GitHub Personal Access Token (required for API access)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo
GITHUB_TOKEN=your_token_here

# Target repositories (comma-separated owner/repo)
TARGET_REPOS=apache/spark,microsoft/vscode,kubernetes/kubernetes

# Data directory
DATA_DIR=data

# Model output directory
MODEL_DIR=models

# Random seed for reproducibility
RANDOM_SEED=42
